# Environment Configuration Example for AI Orchestrator
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ================== APP CONFIGURATION ==================
APP_NAME="AI Orchestrator"
ENVIRONMENT=development
APP_MODE=development
LOG_LEVEL=INFO

# ================== DATABASE ==================
# Development: SQLite (default)
# Production: PostgreSQL or other enterprise DB
DATABASE_URL=sqlite:///./ai_orchestrator.db

# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_orchestrator

# ================== REDIS ==================
REDIS_URL=redis://localhost:6379/0

# ================== API SECURITY ==================
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
API_TOKEN=your-api-token-here

# ================== CORS & SECURITY ==================
# Development: Allow localhost
# Production: Specify exact origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Public URLs (MUST be HTTPS in production)
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# ================== JWT AUTHENTICATION ==================
# CRITICAL: Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Minimum 32 characters, must be strong in production
JWT_SECRET_KEY=your-super-secret-jwt-key-32-chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ================== OAUTH2 PROVIDERS ==================

# Google OAuth2
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# GitHub OAuth2
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# ================== STRIPE BILLING ==================
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_* for development, sk_live_* for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ================== MONITORING ==================
# Sentry error tracking (optional)
SENTRY_DSN=https://your-key@sentry.io/project-id

# ================== DEMO MODE ==================
# Enable public demo without authentication
PUBLIC_DEMO_MODE=false

# Auto-seed demo data on startup
AUTO_SEED_DEMO=false

# ================== SECURITY HARDENING ==================

# Enable security headers (HSTS, CSP, X-Frame-Options, etc.)
ENABLE_SECURITY_HEADERS=true

# HSTS max age in seconds (default: 1 year)
HSTS_MAX_AGE=31536000

# X-Frame-Options: DENY, SAMEORIGIN, ALLOW-FROM <uri>
X_FRAME_OPTIONS=DENY

# Secure cookies (HTTPS-only)
SECURE_COOKIES=true

# SameSite cookie policy: strict, lax, none
SAMESITE_COOKIES=strict

# Enable CORS
ENABLE_CORS=true
CORS_ALLOW_CREDENTIALS=true

# ================== NOTES ==================
# 1. NEVER commit .env to version control
# 2. ALL SECRETS must be generated/obtained securely
# 3. In production, use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc.)
# 4. Generate JWT_SECRET_KEY with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# 5. Keep backups of production secrets in secure location
# 6. Rotate secrets regularly (especially JWT keys)
# 7. Use HTTPS in production (enforce with PUBLIC_APP_URL and PUBLIC_API_URL)
# 8. Set SECURE_COOKIES=true in production
# 9. Limit ALLOWED_ORIGINS to specific domains in production
# 10. Monitor Sentry for errors in production
