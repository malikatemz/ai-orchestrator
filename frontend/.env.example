NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Set this to your real HTTPS domain in production. Placeholder or localhost values now force noindex/disallow crawl behavior for safety.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional: Use a frontend-managed token for API calls (client-side localStorage is used in the dashboard)
NEXT_PUBLIC_API_TOKEN=
